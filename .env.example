# Optional: copy to .env and adjust

# Application
APP_TITLE=snomed
APP_DEBUG=false
LOG_LEVEL=INFO

# Database (URL is built from these in config)
DB_SCHEME=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USER=snomed
DB_PASSWORD=
DB_NAME=snomed

# SQLite: use DB_SCHEME=sqlite and DB_NAME as path, e.g. ./snomed.db
# MySQL: DB_SCHEME=mysql, DB_PORT=3306, and add: uv add aiomysql

# RAG / pgvector (optional; requires PostgreSQL with pgvector extension)
# If using PostgreSQL for main DB, vector URL is built from DB_* as postgresql+psycopg://...
# Otherwise set VECTOR_DATABASE_URL to a postgresql+psycopg://... URL
# VECTOR_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/snomed
# RAG_COLLECTION_NAME=snomed_vectors
# RAG_EMBEDDING_MODEL=BAAI/bge-large-en
# RAG_TOP_K=5

# LLM (OpenAI) – required for LLM answers in search
# Set this to your OpenAI API key (sk-...)
OPENAI_API_KEY=
